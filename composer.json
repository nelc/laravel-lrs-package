{
    "name": "nelc/laravel-nelc-xapi-integration",
    "description": "xAPI Integration with NELC (National Center for e-Learning)",
    "keywords": [
        "NELC xAPI Integration",
        "xAPI",
        "NELC Saudi"
    ],
    "homepage": "https://github.com/nelc/laravel-nelc-xapi-integration",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Mahmoud Hassan",
            "email": "betalamoud@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3 || ^8.4 || ^8.5",
        "illuminate/support": "^8.0 || ^9.0 || ^10.0 || ^11.0 || ^12.0 || ^13.0",
        "guzzlehttp/guzzle": "^7.2",
        "cuteminded/agent": "^3.0"
    },
    "require-dev": {
        
    },
    "autoload": {
        "psr-4": {
            "Nelc\\LaravelNelcXapiIntegration\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nelc\\LaravelNelcXapiIntegration\\NelcXapiServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
